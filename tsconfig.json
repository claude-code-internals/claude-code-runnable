{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"],
      "bun:bundle": ["./src/stubs/bun-bundle.d.ts"]
    },
    "types": ["bun-types"]
  },
  "include": ["src/**/*", "vendor/**/*", "shims/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
